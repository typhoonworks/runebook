<% if result[:ok] %>
  <% raw_stdout = result[:stdout].to_s %>
  <% lines = raw_stdout.lines %>
  <% last = lines.last&.strip %>
  <% result_line = (last && last.start_with?("=> ")) ? lines.pop : nil %>
  <% output_text = lines.join %>
  <% result_value = result_line ? result_line.sub(/^=> /, '') : result[:result].inspect %>

  <div class="cell-output-region">
    <!-- Stdout output -->
    <% if output_text.strip.present? %>
      <div class="cell-output-row cell-output-stdout group">
        <div class="overflow-auto whitespace-pre-wrap font-mono text-sm text-base-content/80 tiny-scrollbar max-h-80"><%= output_text.strip %></div>
        <button class="cell-output-copy opacity-0 group-hover:opacity-100 transition-opacity"
                title="Copy output"
                data-controller="clipboard"
                data-clipboard-text-value="<%= escape_javascript(output_text.strip) %>"
                data-action="click->clipboard#copy">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />
          </svg>
        </button>
      </div>
    <% end %>

    <!-- Return value -->
    <div class="cell-output-row">
      <span class="cell-output-result-value"><%= result_value %></span>
    </div>
  </div>
<% else %>
  <% err = (result[:stderr].presence || result[:error].presence || "Execution failed").to_s %>

  <div class="cell-output-region cell-output-error">
    <div class="cell-output-row">
      <div class="overflow-auto whitespace-pre-wrap font-mono text-sm tiny-scrollbar max-h-80 text-error"><%= err.strip %></div>
    </div>
  </div>
<% end %>
