<div class="relative"
     data-controller="markdown-cell"
     data-markdown-cell-preview-url-value="<%= markdown_preview_path %>">
  <div class="flex justify-end items-center mb-1 gap-2 min-h-6 opacity-0 pointer-events-none transition-opacity" data-markdown-cell-target="toolbar">
    <button class="text-gray-500 hover:text-gray-700 p-1" title="Edit" data-action="markdown-cell#startEditing">
      <%= inline_svg("icons/pencil", class: "w-4 h-4") %>
    </button>
    <button class="text-gray-500 hover:text-gray-700 p-1" title="Move up" data-action="markdown-cell#moveUp">
      <%= inline_svg("icons/chevron-up", class: "w-4 h-4") %>
    </button>
    <button class="text-gray-500 hover:text-gray-700 p-1" title="Move down" data-action="markdown-cell#moveDown">
      <%= inline_svg("icons/chevron-down", class: "w-4 h-4") %>
    </button>
    <button class="text-gray-500 hover:text-gray-700 p-1" title="Delete" data-action="markdown-cell#delete">
      <%= inline_svg("icons/trash", class: "w-4 h-4") %>
    </button>
  </div>

  <div class="relative">
    <div data-markdown-cell-target="gutter" class="absolute top-0 bottom-0 -left-3 w-1 rounded-lg transition-colors"></div>

    <div class="flex flex-col space-y-1">
      <div class="rounded-lg overflow-hidden border border-base-300 hidden" data-markdown-cell-target="editorWrapper">
        <div data-markdown-cell-target="editor" class="min-h-[100px] bg-[#1e1e1e]">
          <% if defined?(content) %>
            <script type="text/plain" data-content><%= raw(content.to_s) %></script>
          <% end %>
        </div>
      </div>

      <div class="prose max-w-none min-h-6 cursor-text py-1" data-action="click->markdown-cell#activate" data-markdown-cell-target="preview"></div>

      <%= render partial: "cell_insert_row" %>
    </div>
  </div>
</div>
